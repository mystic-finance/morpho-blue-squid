{
    "$schema": "https://cdn.subsquid.io/schemas/commands.json",
    "commands": {
      "clean": {
        "description": "delete all build artifacts",
        "cmd": ["npx", "--yes", "rimraf", "lib"]
      },
      "build": {
        "description": "Build the squid project",
        "deps": ["clean"],
        "cmd": ["tsc"]
      },
      "up": {
        "description": "Start a PG database",
        "cmd": ["docker", "compose", "up", "-d"]
      },
      "down": {
        "description": "Drop a PG database",
        "cmd": ["docker", "compose", "down"]
      },
      "migration:apply:flare": {
        "description": "Apply the DB migrations for Flare",
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && squid-typeorm-migration apply"]
      },
      "migration:apply:plume": {
        "description": "Apply the DB migrations for Plume",
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && squid-typeorm-migration apply"]
      },
      "migration:apply": {
        "description": "Apply DB migrations for both networks",
        "deps": ["migration:apply:flare", "migration:apply:plume"]
      },
      "migration:generate:flare": {
        "description": "Generate DB migration for Flare",
        "deps": ["build", "migration:clean"],
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && squid-typeorm-migration generate"]
      },
      "migration:generate:plume": {
        "description": "Generate DB migration for Plume",
        "deps": ["build", "migration:clean"],
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && squid-typeorm-migration generate"]
      },
      "migration:generate": {
        "description": "Generate DB migrations for both networks",
        "deps": ["migration:generate:flare"]
      },
      "migration:clean": {
        "description": "Clean the migrations folder",
        "cmd": ["npx", "--yes", "rimraf", "./db/migrations"]
      },
      "migration": {
        "deps": ["build"],
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && squid-typeorm-migration generate"],
        "hidden": true
      },
      "codegen": {
        "description": "Generate TypeORM entities from the schema file",
        "cmd": ["squid-typeorm-codegen"]
      },
      "typegen": {
        "description": "Generate data access classes for an ABI file(s) in the ./abi folder",
        "cmd": ["squid-evm-typegen", "./src/abi", {"glob": "./abi/*.json"}, "--multicall"]
      },
      "process:flare": {
        "description": "Start the Flare squid processor",
        "deps": ["build", "migration:apply:flare"],
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && node lib/main.js"]
      },
      "process:plume": {
        "description": "Start the Plume squid processor",
        "deps": ["build", "migration:apply:plume"],
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && node lib/main.js"]
      },
      "process:prod:flare": {
        "description": "Start the Flare squid processor (prod)",
        "deps": ["migration:apply:flare"],
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && node lib/main.js"],
        "hidden": true
      },
      "process:prod:plume": {
        "description": "Start the Plume squid processor (prod)",
        "deps": ["migration:apply:plume"],
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && node lib/main.js"],
        "hidden": true
      },
      "serve:flare": {
        "description": "Start the Flare GraphQL API server on port 4350",
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && squid-graphql-server --port 4350"]
      },
      "serve:plume": {
        "description": "Start the Plume GraphQL API server on port 4351",
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && squid-graphql-server --port 4351"]
      },
      "serve:prod:flare": {
        "description": "Start the Flare GraphQL API server with caching (port 4350)",
        "cmd": ["sh", "-c", "set -a && . ./.env.flare && set +a && squid-graphql-server --port 4350 --dumb-cache in-memory --dumb-cache-ttl 1000 --dumb-cache-size 100 --dumb-cache-max-age 1000"]
      },
      "serve:prod:plume": {
        "description": "Start the Plume GraphQL API server with caching (port 4351)",
        "cmd": ["sh", "-c", "set -a && . ./.env.plume && set +a && squid-graphql-server --port 4351 --dumb-cache in-memory --dumb-cache-ttl 1000 --dumb-cache-size 100 --dumb-cache-max-age 1000"]
      },
      "check-updates": {
        "cmd": ["npx", "--yes", "npm-check-updates", "--filter=/subsquid/", "--upgrade"],
        "hidden": true
      },
      "bump": {
        "description": "Bump @subsquid packages to the latest versions",
        "deps": ["check-updates"],
        "cmd": ["npm", "i", "-f"]
      },
      "open": {
        "description": "Open a local browser window",
        "cmd": ["npx", "--yes", "opener"]
      }
    }
  }

